# Optional: enables FactSet Fundamentals API support. Paste one auth option into .env.local with your real values.
FACTSET_ACCESS_TOKEN=YOUR_FACTSET_OAUTH_ACCESS_TOKEN
FACTSET_USERNAME=USERNAME-SERIAL
FACTSET_API_KEY=YOUR_FACTSET_API_KEY

# Required for Supabase email/password authentication.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVER_ONLY_SUPABASE_SERVICE_ROLE_KEY

# Optional FactSet tuning for US equities. Change only if your FactSet account expects a different symbology.
FACTSET_IDENTIFIER_TYPE=tickerRegion
FACTSET_SYMBOL_SUFFIX=-US
FACTSET_QUOTE_QUALITY=DLY

# Optional: enables Alpha Vantage quote support and options chains when your plan includes it.
ALPHA_VANTAGE_API_KEY=YOUR_ALPHA_VANTAGE_API_KEY

# Optional: enables Finnhub earnings-call transcript metadata and transcript requests.
FINNHUB_API_KEY=YOUR_FINNHUB_API_KEY

# Optional: protects cron endpoints if you call them outside Vercel Cron.
CRON_SECRET=YOUR_RANDOM_CRON_SECRET

# Recommended by SEC fair-access guidance. Use your app/company and contact email.
SEC_USER_AGENT="Financial_Model/0.1 contact@example.com"
